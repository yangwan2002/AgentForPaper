# 复制为 .env 并填入真实值（.env 已被 .gitignore 忽略，不会提交到 git）
#
# ⚠ 安全须知：
#   - 绝不要把真实 API key 写进 .env.example 或提交到仓库。
#   - 若某个 key 曾出现在聊天记录/日志/截图里，视为已泄漏，请立即到对应控制台轮换。

# ---- LLM 网关 ----
# Anthropic 兼容网关（chat.py 默认 PAPER_LLM=anthropic）
ANTHROPIC_API_KEY=
# 携程内部 LLM 网关（若走 ctrip 预设）
CTRIP_LLM_API_KEY=

PAPER_LLM=anthropic
# PAPER_LLM_MODEL=
# PAPER_BASE_URL=
# PAPER_KEY_ENV=ANTHROPIC_API_KEY

# ---- 文献检索 ----
# 生产必须用真实检索：openalex / arxiv / api。mock 为离线假数据，仅供调试，
# 且 chat.py 会 fail-fast 拒绝启动，除非显式 PAPER_ALLOW_MOCK_RETRIEVAL=1。
PAPER_RETRIEVAL=openalex
# PAPER_ALLOW_MOCK_RETRIEVAL=1   # 仅本地无网调试时开启

# ---- 运行配置（可选）----
# PAPER_WORKSPACE_DIR=output
# PAPER_DEADLINE_S=600
# PAPER_TOKEN_BUDGET=0           # 0=不限；生产建议设非 0 上限防失控
# PAPER_MAX_ITERS=40

# ---- 通用代码执行工具 run_python（低风险长尾：拼图/插图/调段落格式等）----
# 默认开启，用子进程隔离（锁工作目录+超时；本机单人够用，但隔离弱：不阻断网络、
# Windows 上不限文件系统范围/内存）。多用户或不信任环境请改用 docker 后端。
# PAPER_RUN_PYTHON=0                 # 关闭该工具
# PAPER_SANDBOX_BACKEND=subprocess   # subprocess（默认，弱隔离）| docker（强隔离，需 Docker）| auto

# ---- 视觉版面验收闸 visual-layout-acceptance（默认关闭）----
# 开启后：docx 版面改动（图跨栏/分栏/字体/转 docx 等）在收尾时被后台渲染成图，用多模态
# 模型"看图"判断版面是否符合诉求，不达标则有界重改、达上限如实上报（不谎报成功）。
# ⚠ 须知：① 要花钱（每次评估=一次渲染+一次多模态调用）；② 若多模态模型是外部 API，
#   你的论文页面图会被发送出去（数据外泄）；③ 缺 Word/LibreOffice 或未配多模态模型时
#   自动优雅降级、跳过，不影响主流程；④ Word COM 渲染=Word 自身版面（Windows 优先），
#   无 Word 时回退 LibreOffice（与你 Word 里可能有差异，会附保真告警）。
# PAPER_VISUAL_ACCEPTANCE=1          # 开启（默认关）
# PAPER_VLM_PROVIDER=                # 多模态 provider（预设厂商名 / mock；空=不启用）
# PAPER_VLM_MODEL=                   # 多模态（vision）模型名
# PAPER_VLM_BASE_URL=
# PAPER_VLM_API_KEY=                 # 多模态模型 API key（对应 vlm_api_key_env）
# PAPER_VISUAL_MAX_ROUNDS=1          # 视觉不满足时的有界重改轮数上限
# PAPER_VISUAL_DPI=150               # 渲染 DPI
# PAPER_VISUAL_MAX_PAGES=6           # 送多模态模型的页数天花板（优先送变化页）
# PAPER_SOFFICE_PATH=                # LibreOffice soffice 路径（Word 不可用时的回退渲染后端）

# ---- 其他可选厂商 ----
# OPENAI_API_KEY=
# DASHSCOPE_API_KEY=
# DEEPSEEK_API_KEY=
# MOONSHOT_API_KEY=
# ZHIPU_API_KEY=
